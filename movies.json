  "_metadata": {
    "description": "Self-documenting movie and TV show data store with embedded PowerShell mutation instructions.",
    "schema_version": "1.1.0",
    "instructions": {
      "context": "When the user provides this JSON file and asks to add or modify records, parse the active log. Do not rewrite the file. Instead, generate the exact PowerShell command string required to execute the change locally based on the syntax defined below.",
      "syntax": {
        "add_entry": "Add-MovieEntry -Title 'Movie Title' -Rating 5 -WatchDate 'YYYY-MM-DD' -ReleaseDate 'YYYY-MM-DD' -Runtime 'HH:MM:SS' -Genre 'Genre1, Genre2' -Director 'Director Name' -Studio 'Studio Name' -Actors 'Actor 1, Actor 2' -Notes 'Optional notes'",
        "update_property": "Update-MovieEntry -Title 'Movie Title' -Property 'WatchDate' -Value 'YYYY-MM-DD'"
      }
    }
  },
