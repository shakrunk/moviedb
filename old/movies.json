        "add_entry": "Add-MovieEntry -Title 'Movie Title' -Rating 5 -ReleaseDate 'YYYY-MM-DD' -Genre 'Genre1, Genre2' -Director 'Director Name' -Notes 'Optional notes'",
        "update_rating": "Update-MovieEntry -Title 'Movie Title' -Property 'Rating' -Value 4"
      }
    }
